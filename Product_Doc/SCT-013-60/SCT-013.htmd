    error: function() {
    }
});
}

var $ipt = $('#sSearchword'),
$clearIpt = $('#searchclearyo');

$ipt.keyup(function(){
$("#searchclearyo").toggle(Boolean($(this).val()));
});

$clearIpt.toggle(Boolean($ipt.val()));
$clearIpt.click(function(){
  $("#sSearchword").val('').focus();
  $(this).hide();
});
function checkRecaptcha() {
  var response = grecaptcha.getResponse();
  if(response.length == 0) { 
    alert("Before you proceed to the download, please complete the captcha below.");
		return false;
  }
  else { 
		return true;
  }
}
</script>

<script language="javascript">
function checkCode(theForm) {
	if (theForm.innum.value.replace(/ /gi,"").length == 5 && theForm.innum.value.substring(0,1) == "1" && theForm.innum.value.substring(1,2) == "6" && theForm.innum.value.substring(2,3) == "6" && theForm.innum.value.substring(3,4) == "9" && theForm.innum.value.substring(4,5) == "9") {
		return true;
	} else {
		alert("Invalid input. Please try again");
		theFormnum.value="";
		theForm.innum.focus();
		return false;
	}
}
</script>

